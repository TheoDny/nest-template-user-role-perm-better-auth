{
    "name": "nestjs-better-auth-api",
    "version": "0.1.0",
    "private": true,
    "description": "NestJS API with Better Auth, Prisma, organizations, roles, members, and invitations.",
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.ts\" \"*.json\" \"*.md\" --ignore-unknown --no-error-on-unmatched-pattern && prisma format",
        "lint": "eslint \"{src,test}/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:prod": "node dist/main.js",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:seed": "prisma db seed",
        "prisma:studio": "prisma studio"
    },
    "prisma": {
        "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@thallesp/nestjs-better-auth": "^2.6.1",
        "better-auth": "^1.6.11",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "dotenv": "^17.4.2",
        "mjml": "^4.15.0",
        "nodemailer": "^6.9.16",
        "pg": "^8.21.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/mjml": "^4.7.4",
        "@types/node": "^22.0.0",
        "@types/nodemailer": "^6.4.16",
        "@types/supertest": "^6.0.2",
        "eslint": "^9.0.0",
        "jest": "^30.0.0",
        "prettier": "^3.3.3",
        "prisma": "^7.8.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.0.0"
    },
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=10.0.0"
    },
    "packageManager": "pnpm@11.5.2"
}
